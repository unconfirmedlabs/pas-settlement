{
	"name": "@unconfirmed/pas-settlement",
	"version": "0.0.1",
	"description": "A composable settlement-pipeline SDK built on @mysten/pas (the Sui Permissioned Assets Standard).",
	"license": "Apache-2.0",
	"author": "Unconfirmed Labs, Inc.",
	"type": "module",
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs",
			"default": "./dist/index.mjs"
		}
	},
	"sideEffects": false,
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"build": "rm -rf dist && tsc --noEmit && tsdown",
		"typecheck": "tsc --noEmit",
		"test": "vitest run unit",
		"demo": "tsx scripts/settlement-demo.ts",
		"codegen": "sui-ts-codegen generate",
		"format": "prettier -w --ignore-unknown .",
		"format:check": "prettier -c --ignore-unknown ."
	},
	"peerDependencies": {
		"@mysten/pas": ">=0.2.0",
		"@mysten/sui": "^2.16.2"
	},
	"devDependencies": {
		"@mysten/sui": "^2.16.2",
		"@types/node": "^25.0.8",
		"prettier": "^3.7.4",
		"tsdown": "0.20.0-beta.1",
		"tsx": "^4.19.2",
		"typescript": "^5.9.3",
		"vitest": "^4.0.17"
	}
}
